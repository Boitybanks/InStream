# Copy to .env and fill in for local development.

# Database
# Port 5433 (not 5432) — this machine already has a native Postgres service
# bound to 5432, so the Docker Postgres in infra/docker-compose.yml is
# remapped to avoid the conflict.
DATABASE_URL=postgresql+psycopg://instream:instream@localhost:5433/instream

# Redis (Celery broker/result backend)
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=dev-only-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# Local blob storage (Phase 1 stand-in for S3)
STORAGE_ROOT=.data/storage

# Provider selection — "mock" is the only implemented option in Phase 1.
OCR_PROVIDER=mock
AI_PROVIDER=mock

# Reserved for later phases (not read yet):
# AZURE_DOCUMENT_INTELLIGENCE_KEY=
# AWS_TEXTRACT_REGION=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
